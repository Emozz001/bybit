# Bybit AI Trading Platform - Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real credentials to version control

# ============================================
# EXCHANGE API CREDENTIALS (Required for Live Trading)
# ============================================
BYBIT_API_KEY=your_api_key_here
BYBIT_SECRET_KEY=your_secret_key_here
BYBIT_TESTNET=true

# ============================================
# TRADING SETTINGS
# ============================================
TRADING_MODE=paper          # paper or live
MIN_NET_PROFIT_PCT=0.1
MAX_TRADE_SIZE_USDT=100.0
DAILY_LOSS_LIMIT_USDT=50.0
DEFAULT_LEVERAGE=1.0

# ============================================
# RISK MANAGEMENT
# ============================================
MAX_DAILY_LOSS_USDT=100.0
MAX_LEVERAGE=10.0
KILL_SWITCH_ENABLED=false

# ============================================
# LOGGING & PERFORMANCE
# ============================================
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
PERFORMANCE_PROFILE=balanced  # low, balanced, high

# ============================================
# NOTIFICATIONS (Optional)
# ============================================
NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ============================================
# DATABASE
# ============================================
DATABASE_PATH=data/bybit_ai.db
